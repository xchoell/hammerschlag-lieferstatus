# ──────────────────────────────────────────────────────────────────────────
# Xentral-Anbindung
# ──────────────────────────────────────────────────────────────────────────
# Basis-URL der Instanz, OHNE abschließenden Slash.
# Leer lassen und stattdessen über /admin pflegen (empfohlen).
XENTRAL_BASE_URL=

# Personal Access Token (PAT) der Xentral-Instanz.
# Erstellen unter: Administration > Account settings > Developer settings > Personal Access Tokens
# WICHTIG: Der Token hat volle Rechte -> NUR serverseitig, niemals ins Frontend.
# Lieferstatus (read-only): salesOrder:read, deliveryNote:read
# Retoure-Flow (MVP0) zusaetzlich: returnReason:read, return:create, return:update
#   (Freigabe/Label). Least-Privilege: nur diese Scopes, NICHT ["*"] wie das alte
#   returns-portal-Token. Der PAT signiert zugleich die Retoure-Tokens.
XENTRAL_API_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# Betrieb
# ──────────────────────────────────────────────────────────────────────────
PORT=3000
# Bind-Adresse. Hinter Reverse-Proxy (VPS): 127.0.0.1 (nur lokal erreichbar).
# Für direkten Zugriff (Docker/Test ohne Proxy): 0.0.0.0
HOST=127.0.0.1

# MOCK-Modus: true = ohne echte Instanz lauffähig (Demo-Daten in src/mock.js).
# Standard: false (echter Betrieb). Bei Bedarf über /admin umschalten.
USE_MOCK=false

# ──────────────────────────────────────────────────────────────────────────
# Carrier-Tracking (Zustellstatus direkt beim Versanddienstleister)
# ──────────────────────────────────────────────────────────────────────────
# DHL Shipment Tracking - Unified API. Key holen unter developer.dhl.com
# (Free-Tier: 250 Calls/Tag, 1 Call/5s). Ohne Key bleibt der Status max.
# "Versendet" - "Zugestellt" wird nur bei Carrier-Bestätigung gesetzt.
DHL_API_KEY=
# Service-Code: parcel-de (Standardpaket DE), express (DHL Express), parcel-nl ...
DHL_SERVICE=parcel-de
# Cache-TTL für Carrier-Abfragen in ms (schont Rate-Limit).
DHL_CACHE_TTL_MS=600000

# Nur für Demo ohne DHL-Key: "Zugestellt" notfalls aus dem ERP-Auftragsstatus
# (completed) ableiten. Im echten Betrieb aus lassen.
DELIVERED_FALLBACK_ON_ORDER_STATUS=false

# Retoure erst nach Zustellung erlauben (Delivered-Gate). Default: true.
RETURNS_ONLY_DELIVERED=true

# Voraussichtlicher Liefertag als Fallback: Auftragsdatum + X Werktage (Mo–Fr).
# 0 = aus. Greift NUR, wenn weder Wunschlieferdatum noch ein Carrier-Datum
# vorliegt. Auch über die /admin-Settings-Page einstellbar.
EXPECTED_DELIVERY_WORKING_DAYS=0

# "Lieferdatum überschritten"-Hinweis: zeigt einen Kontakt-Hinweis, wenn der
# voraussichtliche Liefertag + Karenz überschritten ist und noch nicht zugestellt.
DELIVERY_OVERDUE_ENABLED=false
# Karenz in Kalendertagen (0 = sobald der voraussichtliche Liefertag vorbei ist).
DELIVERY_OVERDUE_DAYS=0

# ──────────────────────────────────────────────────────────────────────────
# Sicherheit
# ──────────────────────────────────────────────────────────────────────────
# Rate-Limit pro IP für den Lookup (Schutz gegen Enumeration).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# Wenn hinter Reverse-Proxy/Loadbalancer (VPS): 1, sonst 0.
TRUST_PROXY=0

# Settings-Page (/admin). Kennwort fürs echte Deployment unbedingt ändern!
ADMIN_PASSWORD=Xentral123!
# Login-Gültigkeit in ms (Default 8h).
ADMIN_SESSION_TTL_MS=28800000

# ──────────────────────────────────────────────────────────────────────────
# Branding (white-label fähig)
# ──────────────────────────────────────────────────────────────────────────
BRAND_NAME=Hammerschlag Handwerksbedarf
BRAND_SUPPORT_EMAIL=service@hammerschlag.de
# Akzentfarbe als HEX (Buttons, Logo-Kachel)
BRAND_COLOR=#1a1a1a
# Sekundärfarbe (Outline-Buttons, Zurück-Links)
BRAND_COLOR_SECONDARY=#6b7280
# Footer-Links (leer = ausgeblendet)
BRAND_LINK_SHOP=
BRAND_LINK_IMPRINT=
BRAND_LINK_TERMS=
BRAND_LINK_PRIVACY=
# Artikelpreise (brutto) in der Retoure-Auswahl anzeigen
RETURNS_SHOW_PRICES=false
# Logo im Header. Default /logo.svg (liegt in public/, einfach überschreiben).
# Leer setzen -> Fallback auf Buchstaben-Kachel.
BRAND_LOGO_URL=/logo.svg
